<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <com.inclinometer.app.ui.camera.CameraOverlayView
        android:id="@+id/overlay_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Angle overlay cards -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="16dp"
        android:padding="12dp"
        android:background="#AA000000"
        android:gravity="start"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_overlay_pitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pitch: 0.0°"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tv_overlay_roll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll: 0.0°"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Permission request layout -->
    <LinearLayout
        android:id="@+id/permission_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷"
            android:textSize="64sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tv_permission_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera permission is required for overlay mode."
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:textAlignment="center"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_grant_permission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grant Camera Permission" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
