<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout
      xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:background="#0E0E0E">

      <androidx.fragment.app.FragmentContainerView
          android:id="@+id/nav_host_fragment"
          android:name="androidx.navigation.fragment.NavHostFragment"
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1"
          app:defaultNavHost="true"
          app:navGraph="@navigation/nav_graph" />

      <!-- AdMob banner — 320x50 standard size — replace FrameLayout with AdView when ready -->
      <FrameLayout
          android:id="@+id/ad_banner_container"
          android:layout_width="match_parent"
          android:layout_height="50dp"
          android:background="#111111">

          <View android:layout_width="match_parent" android:layout_height="1dp"
              android:layout_gravity="top" android:background="#2A2A2A" />

          <TextView android:id="@+id/tv_ad_placeholder"
              android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:layout_gravity="center" android:text="ADVERTISEMENT"
              android:textColor="#3A3A3A" android:textSize="10sp"
              android:letterSpacing="0.15" android:fontFamily="sans-serif" />
      </FrameLayout>

  </LinearLayout>